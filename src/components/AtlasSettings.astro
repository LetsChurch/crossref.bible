<dialog class="settings-dialog" id="atlas-settings" aria-labelledby="settings-title">
	<form class="settings-sheet" method="dialog">
		<header class="settings-heading">
			<div>
				<p>Atlas display</p>
				<h2 id="settings-title">Settings</h2>
			</div>
			<button class="settings-close" type="submit" value="close" aria-label="Close settings">
				<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 6 12 12M18 6 6 18"></path></svg>
			</button>
		</header>

		<p class="settings-intro">Tune the atlas for your display. Changes are saved on this device.</p>

		<div class="settings-controls">
			<div class="setting setting-with-range">
				<div class="setting-copy">
					<label for="settings-exposure">Exposure</label>
					<p id="settings-exposure-description">Adjust the overall brightness of the atlas.</p>
				</div>
				<output id="settings-exposure-output" for="settings-exposure">0.72×</output>
				<input
					class="setting-range"
					id="settings-exposure"
					type="range"
					min="35"
					max="135"
					value="72"
					aria-describedby="settings-exposure-description"
				/>
			</div>

			<div class="setting setting-with-range">
				<div class="setting-copy">
					<label for="settings-glow">Glow intensity</label>
					<p id="settings-glow-description">Control the bloom around verses and connections.</p>
				</div>
				<output id="settings-glow-output" for="settings-glow">50%</output>
				<input
					class="setting-range"
					id="settings-glow"
					type="range"
					min="0"
					max="100"
					value="50"
					aria-describedby="settings-glow-description"
				/>
			</div>

			<label class="setting setting-with-toggle" for="settings-connections">
				<span class="setting-copy">
					<span class="setting-label">Ambient connections</span>
					<span class="setting-description">Show the background web between verses.</span>
				</span>
				<input id="settings-connections" type="checkbox" role="switch" checked />
			</label>

			<label class="setting setting-with-toggle" for="settings-stars">
				<span class="setting-copy">
					<span class="setting-label">Background stars</span>
					<span class="setting-description">Show the distant points behind the canon.</span>
				</span>
				<input id="settings-stars" type="checkbox" role="switch" checked />
			</label>

			<label class="setting setting-with-toggle" for="settings-idle-motion">
				<span class="setting-copy">
					<span class="setting-label">Idle drift</span>
					<span class="setting-description" id="settings-idle-motion-description">Gently move the atlas after a few seconds.</span>
				</span>
				<input id="settings-idle-motion" type="checkbox" role="switch" aria-describedby="settings-idle-motion-description" checked />
			</label>
		</div>

		<footer class="settings-actions">
			<button id="settings-reset" type="button">Reset defaults</button>
			<button class="settings-done" type="submit" value="close">Done</button>
		</footer>
	</form>
</dialog>

