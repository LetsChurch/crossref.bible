<main id="reference-browser" data-state="loading">
	<div class="atmosphere" aria-hidden="true"></div>

	<header class="topbar">
		<a class="wordmark" href="/" aria-label="Bible Connections home">
			<span></span>
			Bible Connections
		</a>
		<nav class="view-switch" aria-label="Cross-reference view">
			<a href="/">Visual</a>
			<span aria-current="page">List</span>
		</nav>
	</header>

	<section class="intro" aria-labelledby="list-title">
		<p class="eyebrow"><span></span> The complete index</p>
		<h1 id="list-title">Every connection,<br /><em>in canonical order.</em></h1>
		<p class="deck">
			Browse all 344,794 cross-references from Genesis to Revelation. Filter either side of the
			connection, then open any passage on Lets.Bible.
		</p>
	</section>

	<section class="list-card" aria-labelledby="browser-title">
		<div class="list-heading">
			<div>
				<p>Cross-reference index</p>
				<h2 id="browser-title">Browse the connections</h2>
			</div>
			<p class="result-summary" id="result-summary" aria-live="polite">Loading references…</p>
		</div>

		<form class="filters" id="reference-filters">
			<label>
				<span>From book</span>
				<select id="source-book" name="from" disabled>
					<option value="">Loading books…</option>
				</select>
			</label>
			<span class="filter-arrow" aria-hidden="true">→</span>
			<label>
				<span>To book</span>
				<select id="target-book" name="to" disabled>
					<option value="">Loading books…</option>
				</select>
			</label>
			<button id="reset-filters" type="reset" disabled>Reset</button>
		</form>

		<div class="column-headings" aria-hidden="true">
			<span>Source passage</span>
			<span></span>
			<span>Referenced passage</span>
		</div>

		<ol class="reference-list" id="reference-list" aria-busy="true">
			{Array.from({ length: 6 }, (_, index) => (
				<li class="reference-row skeleton-row" aria-hidden="true" data-index={index}>
					<div><i></i><b></b></div>
					<span></span>
					<div><i></i><b></b></div>
				</li>
			))}
		</ol>

		<div class="list-error" id="list-error" role="alert" hidden>
			<p>The cross-reference index could not be loaded.</p>
			<button id="retry-load" type="button">Try again</button>
		</div>

		<div class="list-sentinel" id="list-sentinel" role="status" hidden>
			<i aria-hidden="true"></i>
			<span>Loading more references…</span>
		</div>
	</section>

	<footer class="page-footer">
		<p>
			Cross-reference data from
			<a href="https://www.openbible.info/labs/cross-references/">OpenBible.info</a>
			<span aria-hidden="true">·</span>
			<a href="https://creativecommons.org/licenses/by/4.0/" rel="license">CC BY 4.0</a>
		</p>
		<nav aria-label="Related sites">
			<a href="https://lets.church/">Lets.Church</a>
			<span aria-hidden="true">·</span>
			<a href="https://lets.bible/">Lets.Bible</a>
		</nav>
	</footer>
</main>

<script>
	import '../scripts/cross-reference-list';
</script>

